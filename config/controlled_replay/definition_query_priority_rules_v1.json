{
  "experiment_id": "definition_query_primary_prioritization_v1",
  "enabled_by_default": true,
  "env_flag": "TCM_ENABLE_DEFINITION_QUERY_PRIORITY_RULES_V1",
  "query_prefix_noise": [
    "请问",
    "书中",
    "文中",
    "伤寒论里",
    "伤寒论中",
    "关于",
    "对于"
  ],
  "query_suffix_noise": [
    "呢",
    "呀",
    "啊"
  ],
  "block_hints": [
    "条文",
    "原文",
    "出处",
    "出自",
    "组成",
    "药味",
    "比较",
    "区别",
    "不同",
    "异同",
    "怎么办",
    "怎么处理",
    "如何处理",
    "如何治疗"
  ],
  "primary_limit": 1,
  "secondary_limit": 5,
  "source_object_bonus": {
    "definition_terms": 14.0,
    "main_passages": 8.0,
    "passages": 6.0
  },
  "evidence_type_weights": {
    "exact_term_definition": 180.0,
    "subject_predicate_definition": 176.0,
    "subject_category_definition": 172.0,
    "exact_term_explanation": 152.0,
    "term_membership_sentence": 144.0,
    "subject_predicate_explanation": 132.0
  },
  "families": [
    {
      "family_id": "what_is",
      "label": "X是什么",
