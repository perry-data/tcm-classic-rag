{
  "policy_name": "zjshl_layered_enablement_policy",
  "version": "2026-04-02",
  "scope": "《伤寒论》研读支持系统的数据分层启用策略",
  "datasets": {
    "safe": "zjshl_dataset_v2_mvp_safe.zip",
    "full": "zjshl_dataset_v2.zip"
  },
  "level_definitions": {
    "A": {
      "name": "primary_evidence",
      "description": "可直接作为主证据展示"
    },
    "B": {
      "name": "secondary_evidence",
      "description": "可作为辅助证据展示，但不能替代主证据"
    },
    "C": {
      "name": "retrieval_only_risk",
      "description": "可参与召回和风险判断，默认不直接作为证据展示"
    },
    "D": {
      "name": "disabled",
      "description": "当前阶段默认禁用"
    }
  },
  "retrieval_candidate_sources": [
    {
      "source_id": "safe_chunks",
      "dataset": "safe",
      "object": "chunks",
      "level": "C",
      "retrieval_allowed": true,
      "display_allowed": "preview_only",
      "default_weight_tier": "highest",
      "notes": "第一阶段召回主骨架；命中后必须回指 main_passages。"
    },
    {
      "source_id": "safe_main_passages_primary",
      "dataset": "safe",
      "object": "main_passages",
      "filter": "retrieval_primary=true",
      "level": "A",
      "retrieval_allowed": true,
      "display_allowed": "primary",
      "default_weight_tier": "high",
      "notes": "主证据层核心对象。"
    },
    {
      "source_id": "safe_main_passages_secondary",
      "dataset": "safe",
      "object": "main_passages",
      "filter": "retrieval_primary=false",
      "level": "B",
      "retrieval_allowed": true,
      "display_allowed": "secondary",
      "default_weight_tier": "medium",
      "notes": "保留但降级的短主条，只能作辅助证据。"
    },
    {
      "source_id": "full_annotations_raw",
      "dataset": "full",
      "object": "annotations",
      "level": "B",
      "retrieval_allowed": true,
      "display_allowed": "conditional_secondary",
      "default_weight_tier": "medium_low",
      "risk_flag": [
        "annotation_unlinked"
      ],
      "requires_disclaimer": true,
      "notes": "仅按注解原文片段使用，不依赖 annotation_links 自动挂接。"
    },
    {
      "source_id": "full_passages_ledger",
      "dataset": "full",
      "object": "passages",
      "level": "C",
      "retrieval_allowed": true,
      "display_allowed": "risk_only",
      "default_weight_tier": "low",
      "risk_flag": [
        "ledger_mixed_roles"
      ],
      "requires_disclaimer": true,
      "notes": "全量文本总账，用于兜底召回、回溯和上下文补全。"
    },
    {
      "source_id": "ambiguous_related_material",
      "dataset": "full",
      "object": "ambiguous_passages",
      "level": "C",
      "retrieval_allowed": true,
      "display_allowed": "risk_only",
      "default_weight_tier": "lowest",
      "risk_flag": [
        "ambiguous_source"
      ],
      "requires_disclaimer": true,
      "notes": "只参与低权重召回和风险模式，不得作为主证据。"
    }
  ],
  "primary_evidence_sources": [
    {
      "source_id": "safe_main_passages_primary",
      "dataset": "safe",
      "object": "main_passages",
      "filter": "retrieval_primary=true",
      "level": "A",
      "display_section": "primary_evidence",
      "citation_role": "canonical"
    }
  ],
  "secondary_evidence_sources": [
    {
      "source_id": "safe_main_passages_secondary",
      "dataset": "safe",
      "object": "main_passages",
      "filter": "retrieval_primary=false",
      "level": "B",
      "display_section": "secondary_evidence",
      "requires_disclaimer": false,
      "citation_role": "supplementary"
    },
    {
      "source_id": "full_annotations_raw",
      "dataset": "full",
      "object": "annotations",
      "level": "B",
      "display_section": "secondary_evidence",
      "requires_disclaimer": true,
      "risk_flag": [
        "annotation_unlinked"
      ],
      "citation_role": "annotation_reference"
    }
  ],
  "disabled_sources": [
    {
      "source_id": "full_annotation_links",
      "dataset": "full",
      "object": "annotation_links",
      "level": "D",
      "retrieval_allowed": false,
      "display_allowed": false,
      "reason": "验收阶段已确认错挂，且存在批量疑似风险。"
    },
    {
      "source_id": "derived_annotation_evidence_chain",
      "dataset": "full",
      "object": "annotation_links",
      "level": "D",
      "retrieval_allowed": false,
      "display_allowed": false,
      "reason": "未通过验收前，禁止把 annotation_links 派生成正文-注解证据链。"
    },
    {
      "source_id": "unsafe_raw_chunks_as_index",
      "dataset": "full",
      "object": "chunks",
      "level": "D",
      "retrieval_allowed": false,
      "display_allowed": false,
      "reason": "被 safe 策略排除的原始 chunks 不再作为独立索引对象启用。"
    }
  ],
  "risk_labels": {
    "annotation_unlinked": {
      "label": "注解参考（未启用自动挂接）",
      "display_style": "warning",
      "effect": "只能作为辅助说明展示"
    },
    "ambiguous_source": {
      "label": "低置信度 / 待核对",
      "display_style": "danger",
      "effect": "不得作为主证据"
    },
    "ledger_mixed_roles": {
      "label": "总账回查材料",
      "display_style": "muted",
      "effect": "默认不直接展示为证据"
    },
    "strong_evidence_insufficient": {
      "label": "强证据不足",
      "display_style": "warning",
      "effect": "回答必须弱化或拒答"
    },
    "retrieval_only_material": {
      "label": "仅召回候选",
      "display_style": "muted",
      "effect": "默认仅后台使用"
    }
  },
  "answer_modes": {
    "strong": {
      "requires_level_a": true,
      "allows_levels": [
        "A",
        "B"
      ],
      "default_user_message": "基于主证据回答",
      "display_sections": [
        "primary_evidence",
        "secondary_evidence"
      ]
    },
    "strong_with_auxiliary": {
      "requires_level_a": true,
      "requires_level_b": true,
      "allows_levels": [
        "A",
        "B"
      ],
      "default_user_message": "基于主证据回答，并附带辅助说明",
      "display_sections": [
        "primary_evidence",
        "secondary_evidence"
      ]
    },
    "weak_with_review_notice": {
      "requires_level_a": false,
      "requires_level_b_or_c": true,
      "allows_levels": [
        "B",
        "C"
      ],
      "must_add_risk_labels": [
        "strong_evidence_insufficient"
      ],
      "default_user_message": "仅命中辅助或风险材料，以下内容需核对",
      "display_sections": [
        "secondary_evidence",
        "review_materials"
      ]
    },
    "refuse": {
      "requires_level_a": false,
      "requires_level_b_or_c": false,
      "allows_levels": [],
      "default_user_message": "未找到足以支撑回答的依据，建议缩小问题范围或改问具体条文",
      "display_sections": []
    }
  },
  "stage_policy": {
    "retrieval_stage": {
      "allowed_levels": [
        "A",
        "B",
        "C"
      ],
      "blocked_levels": [
        "D"
      ],
      "priority_order": [
        "safe_chunks",
        "safe_main_passages_primary",
        "safe_main_passages_secondary",
        "full_annotations_raw",
        "full_passages_ledger",
        "ambiguous_related_material"
      ]
    },
    "evidence_selection_stage": {
      "primary_must_come_from": [
        "safe_main_passages_primary"
      ],
      "secondary_may_come_from": [
        "safe_main_passages_secondary",
        "full_annotations_raw"
      ],
      "risk_only_sources": [
        "safe_chunks",
        "full_passages_ledger",
        "ambiguous_related_material"
      ],
      "disabled_sources": [
        "full_annotation_links",
        "derived_annotation_evidence_chain",
        "unsafe_raw_chunks_as_index"
      ]
    },
    "answer_generation_stage": {
      "prompt_slots": {
        "primary_evidence": [
          "safe_main_passages_primary"
        ],
        "secondary_evidence": [
          "safe_main_passages_secondary",
          "full_annotations_raw"
        ],
        "risk_materials": [
          "full_passages_ledger",
          "ambiguous_related_material"
        ]
      },
      "hard_rules": [
        "no_level_a_means_no_strong_answer",
        "level_b_cannot_replace_level_a",
        "level_c_never_becomes_primary_evidence",
        "level_d_never_enters_prompt"
      ]
    }
  },
  "future_gray_enable_conditions": {
    "annotation_links": {
      "current_status": "disabled",
      "must_meet": [
        "confirmed mislinks fixed",
        "heuristic suspicious links re-audited or regenerated",
        "severe mislink count reduced to zero in new acceptance round",
        "only a validated subset may enter gray release"
      ]
    }
  }
}
