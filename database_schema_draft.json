{
  "schema_name": "zjshl_database_schema_mvp_draft",
  "version": "2026-04-03",
  "policy_reference": {
    "policy_markdown": "docs/06_layered_enablement_policy.md",
    "policy_json": "layered_enablement_policy.json",
    "field_mapping_markdown": "docs/layered_field_mapping.md"
  },
  "source_resolution": {
    "safe": {
      "artifact": "dist/zjshl_dataset_v2_mvp_safe.zip",
      "load_objects": [
        "main_passages",
        "chunks"
      ],
      "skip_objects": [
        "annotations",
        "passages",
        "ambiguous_passages",
        "annotation_links"
      ],
      "notes": [
        "safe main_passages contains both Level A and Level B runtime labels",
        "safe chunks are the only chunk source enabled for retrieval"
      ]
    },
    "full": {
      "artifact_expected": "dist/zjshl_dataset_v2.zip",
      "artifact_used_for_field_audit": "data/processed/zjshl_dataset_v2",
      "load_objects": [
        "annotations",
        "passages",
        "ambiguous_passages"
      ],
      "skip_as_runtime_sources": [
        "main_passages",
        "chunks",
        "annotation_links"
      ],
      "notes": [
        "full annotations are loaded as unlinked auxiliary material",
        "full passages are loaded as ledger fallback only",
        "ambiguous_passages are loaded as a dedicated risk registry",
        "full main_passages and full chunks do not become independent runtime tables; their risk fallback semantics are covered by records_passages plus risk_registry_ambiguous"
      ]
    }
  },
  "common_policy_fields": [
    {
      "name": "record_id",
      "type": "string",
      "required": true,
      "description": "Runtime primary key, recommended format dataset_variant:source_object:source_record_id"
    },
    {
      "name": "source_record_id",
      "type": "string",
      "required": true,
      "description": "Original object key such as passage_id, chunk_id, or link_id"
    },
    {
      "name": "dataset_variant",
      "type": "string",
      "required": true,
      "description": "safe or full"
    },
    {
      "name": "source_object",
      "type": "string",
      "required": true,
      "description": "Original object type"
    },
    {
      "name": "source_type",
      "type": "string",
      "required": true,
      "description": "Business role type"
    },
    {
      "name": "retrieval_allowed",
      "type": "boolean",
      "required": true,
      "description": "Whether the record can enter retrieval"
    },
    {
      "name": "evidence_level",
      "type": "string",
      "required": true,
      "description": "A, B, C, or D"
    },
    {
      "name": "display_allowed",
      "type": "string",
      "required": true,
      "description": "primary, secondary, risk_only, preview_only, or false"
    },
    {
      "name": "risk_flag",
      "type": "json_array_string",
      "required": true,
      "description": "Risk labels array; use [] when no risk label applies"
    },
    {
      "name": "requires_disclaimer",
      "type": "boolean",
      "required": true,
      "description": "Whether the frontend must show a disclaimer if displayed"
    },
    {
      "name": "default_weight_tier",
      "type": "string",
      "required": true,
      "description": "highest, high, medium, medium_low, low, lowest, off"
    },
    {
      "name": "policy_source_id",
      "type": "string",
      "required": true,
      "description": "Source id from layered_enablement_policy.json"
    },
    {
      "name": "policy_version",
      "type": "string",
      "required": true,
      "description": "Policy version carried into runtime rows"
    }
  ],
  "tables": [
    {
      "name": "records_main_passages",
      "required": true,
      "grain": "one row per safe main_passages record",
      "primary_key": "record_id",
      "source_file": "safe/main_passages.json",
      "runtime_role": "primary and secondary evidence source",
      "fields": [
        "record_id",
        "source_record_id",
        "passage_id",
        "dataset_variant",
        "source_object",
        "source_type",
        "book_id",
        "chapter_id",
        "chapter_name",
        "chapter_type",
        "passage_order_in_chapter",
        "source_file",
        "source_item_no",
        "text",
        "normalized_text",
        "text_role",
        "role_confidence",
        "anchor_passage_id",
        "retrieval_primary_raw",
        "retrieval_allowed",
        "evidence_level",
        "display_allowed",
        "risk_flag",
        "requires_disclaimer",
        "default_weight_tier",
        "policy_source_id",
        "policy_version"
      ],
      "derived_rules": [
        "dataset_variant = safe",
        "source_object = main_passages",
        "source_type = main_text",
        "retrieval_allowed = true",
        "if retrieval_primary_raw is true then evidence_level = A, display_allowed = primary, risk_flag = [], default_weight_tier = high, policy_source_id = safe_main_passages_primary",
        "if retrieval_primary_raw is false then evidence_level = B, display_allowed = secondary, risk_flag = [short_text_demoted], default_weight_tier = medium, policy_source_id = safe_main_passages_secondary"
      ]
    },
    {
      "name": "records_chunks",
      "required": true,
      "grain": "one row per safe chunks record",
      "primary_key": "record_id",
      "source_file": "safe/chunks.json",
      "runtime_role": "first-pass retrieval skeleton and preview source",
      "fields": [
        "record_id",
        "source_record_id",
        "chunk_id",
        "dataset_variant",
        "source_object",
        "source_type",
        "book_id",
        "chapter_id",
        "chapter_name",
        "chunk_type",
        "retrieval_tier_raw",
        "chunk_text",
        "normalized_text",
        "source_passage_ids_json",
        "source_passage_count",
        "retrieval_allowed",
        "evidence_level",
        "display_allowed",
        "risk_flag",
        "requires_disclaimer",
        "default_weight_tier",
        "policy_source_id",
        "policy_version"
      ],
      "derived_rules": [
        "dataset_variant = safe",
        "source_object = chunks",
        "source_type = chunk",
        "retrieval_allowed = true",
        "evidence_level = C",
        "display_allowed = preview_only",
        "risk_flag = []",
        "requires_disclaimer = false",
        "default_weight_tier = highest",
        "policy_source_id = safe_chunks"
      ]
    },
    {
      "name": "record_chunk_passage_links",
      "required": true,
      "grain": "one row per chunk_id to passage_id link extracted from source_passage_ids",
      "primary_key": "link_id",
      "source_file": "safe/chunks.json",
      "runtime_role": "mandatory back-reference bridge from chunks to records_main_passages",
      "fields": [
        "link_id",
        "chunk_record_id",
        "chunk_id",
        "main_passage_record_id",
        "main_passage_id",
        "link_order",
        "backref_source"
      ],
      "derived_rules": [
        "chunk_record_id references records_chunks.record_id",
        "main_passage_record_id references records_main_passages.record_id",
        "backref_source = source_passage_ids"
      ]
    },
    {
      "name": "records_annotations",
      "required": true,
      "grain": "one row per full annotations record",
      "primary_key": "record_id",
      "source_file": "full/annotations.json",
      "runtime_role": "secondary evidence source only",
      "fields": [
        "record_id",
        "source_record_id",
        "annotation_id",
        "passage_id",
        "dataset_variant",
        "source_object",
        "source_type",
        "book_id",
        "chapter_id",
        "chapter_name",
        "chapter_type",
        "passage_order_in_chapter",
        "source_file",
        "source_item_no",
        "text",
        "normalized_text",
        "text_role",
        "role_confidence",
        "source_anchor_passage_id",
        "retrieval_primary_raw",
        "retrieval_allowed",
        "evidence_level",
        "display_allowed",
        "risk_flag",
        "requires_disclaimer",
        "default_weight_tier",
        "policy_source_id",
        "policy_version",
        "linkage_enabled"
      ],
      "derived_rules": [
        "dataset_variant = full",
        "source_object = annotations",
        "source_type = annotation",
        "retrieval_allowed = true",
        "evidence_level = B",
        "display_allowed = secondary",
        "risk_flag = [annotation_unlinked]",
        "requires_disclaimer = true",
        "default_weight_tier = medium_low",
        "policy_source_id = full_annotations_raw",
        "linkage_enabled = false",
        "source_anchor_passage_id is audit-only and must not be used as a runtime join key"
      ]
    },
    {
      "name": "records_passages",
      "required": true,
      "grain": "one row per full passages record",
      "primary_key": "record_id",
      "source_file": "full/passages.json",
      "runtime_role": "ledger fallback and risk-mode support only",
      "fields": [
        "record_id",
        "source_record_id",
        "passage_id",
        "dataset_variant",
        "source_object",
        "source_type",
        "book_id",
        "chapter_id",
        "chapter_name",
        "chapter_type",
        "passage_order_in_chapter",
        "source_file",
        "source_item_no",
        "text",
        "normalized_text",
        "text_role",
        "role_confidence",
        "source_anchor_passage_id",
        "retrieval_primary_raw",
        "retrieval_allowed",
        "evidence_level",
        "display_allowed",
        "risk_flag",
        "requires_disclaimer",
        "default_weight_tier",
        "policy_source_id",
        "policy_version",
        "ambiguous_registry_hit"
      ],
      "derived_rules": [
        "dataset_variant = full",
        "source_object = passages",
        "source_type = ledger_text",
        "retrieval_allowed = true",
        "evidence_level = C",
        "display_allowed = risk_only",
        "default_weight_tier = low",
        "policy_source_id = full_passages_ledger",
        "base risk_flag = [ledger_mixed_roles]",
        "if passage_id exists in risk_registry_ambiguous then append ambiguous_source and set ambiguous_registry_hit = true"
      ]
    },
    {
      "name": "risk_registry_ambiguous",
      "required": true,
      "grain": "one row per full ambiguous_passages record",
      "primary_key": "record_id",
      "source_file": "full/ambiguous_passages.json",
      "runtime_role": "risk registry and lowest-priority retrieval source",
      "fields": [
        "record_id",
        "source_record_id",
        "passage_id",
        "dataset_variant",
        "source_object",
        "source_type",
        "chapter_id",
        "source_file",
        "source_item_no",
        "text",
        "normalized_text",
        "text_role",
        "retrieval_allowed",
        "evidence_level",
        "display_allowed",
        "risk_flag",
        "requires_disclaimer",
        "default_weight_tier",
        "policy_source_id",
        "policy_version",
        "linked_passage_record_id",
        "linked_passage_id"
      ],
      "derived_rules": [
        "dataset_variant = full",
        "source_object = ambiguous_passages",
        "source_type = risk_registry",
        "normalized_text is generated from text at ingest time",
        "retrieval_allowed = true",
        "evidence_level = C",
        "display_allowed = risk_only",
        "risk_flag = [ambiguous_source]",
        "requires_disclaimer = true",
        "default_weight_tier = lowest",
        "policy_source_id = ambiguous_related_material",
        "linked_passage_record_id references records_passages.record_id with the same passage_id"
      ]
    }
  ],
  "optional_tables": [
    {
      "name": "disabled_annotation_links",
      "required": false,
      "recommended_for_mvp": false,
      "primary_key": "record_id",
      "source_file": "full/annotation_links.json",
      "runtime_role": "audit-only quarantine table",
      "fields": [
        "record_id",
        "source_record_id",
        "dataset_variant",
        "source_object",
        "source_type",
        "from_passage_id",
        "to_passage_id",
        "relation",
        "confidence",
        "retrieval_allowed",
        "evidence_level",
        "display_allowed",
        "risk_flag",
        "requires_disclaimer",
        "default_weight_tier",
        "policy_version"
      ],
      "derived_rules": [
        "dataset_variant = full",
        "source_object = annotation_links",
        "source_type = link_relation",
        "retrieval_allowed = false",
        "evidence_level = D",
        "display_allowed = false",
        "risk_flag = [disabled_link_layer]",
        "default_weight_tier = off"
      ]
    }
  ],
  "logical_views": [
    {
      "name": "vw_retrieval_records_unified",
      "required": true,
      "view_type": "logical_union_view",
      "sources": [
        "records_chunks",
        "records_main_passages",
        "records_annotations",
        "records_passages",
        "risk_registry_ambiguous"
      ],
      "excludes": [
        "disabled_annotation_links",
        "any row where retrieval_allowed = false"
      ],
      "fields": [
        "retrieval_entry_id",
        "record_table",
        "record_id",
        "source_record_id",
        "dataset_variant",
        "source_object",
        "source_type",
        "retrieval_text",
        "normalized_text",
        "book_id",
        "chapter_id",
        "chapter_name",
        "evidence_level",
        "display_allowed",
        "risk_flag",
        "requires_disclaimer",
        "default_weight_tier",
        "policy_source_id",
        "backref_target_type",
        "backref_target_ids_json"
      ],
      "field_rules": [
        "retrieval_text = chunk_text for records_chunks; otherwise retrieval_text = text",
        "backref_target_type = main_passages for records_chunks",
        "backref_target_ids_json for records_chunks comes from record_chunk_passage_links",
        "backref_target_type = none for records_annotations",
        "backref_target_type = passages for risk_registry_ambiguous",
        "rows are ranked first by default_weight_tier, then by retrieval engine score"
      ]
    }
  ],
  "answer_mode_requirements": {
    "strong": {
      "minimum_database_condition": "at least one records_main_passages row with evidence_level = A is selected into primary_evidence",
      "allowed_sources": [
        "records_main_passages",
        "records_annotations"
      ],
      "forbidden_as_primary": [
        "records_chunks",
        "records_passages",
        "risk_registry_ambiguous"
      ]
    },
    "weak_with_review_notice": {
      "minimum_database_condition": "no Level A record selected, but at least one Level B or Level C record selected",
      "required_result_flags": [
        "strong_evidence_insufficient"
      ],
      "allowed_sources": [
        "records_main_passages",
        "records_annotations",
        "records_passages",
        "risk_registry_ambiguous"
      ]
    },
    "refuse": {
      "minimum_database_condition": "no Level A, Level B, or Level C record survives retrieval, backref resolution, and slot filtering",
      "allowed_sources": []
    }
  },
  "hard_runtime_rules": [
    "records_chunks may trigger retrieval but may not become primary_evidence directly",
    "records_annotations may become secondary_evidence only",
    "records_passages and risk_registry_ambiguous may become risk_materials only",
    "annotation_links must remain disabled at the database layer",
    "any automatic正文-注解 evidence chain derived from annotation_links is forbidden in MVP"
  ]
}
