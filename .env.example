TCM_RAG_LLM_API_KEY=your_model_studio_api_key_here
TCM_RAG_LLM_MODEL=qwen-plus
TCM_RAG_LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
TCM_RAG_LLM_ENABLED=true

# Default endpoint above is the Singapore OpenAI-compatible base URL.
# If your key belongs to another region, replace TCM_RAG_LLM_BASE_URL manually.
# Example China (Beijing) endpoint:
# TCM_RAG_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# This release is fixed to Alibaba Cloud Model Studio qwen-plus in non-thinking mode.
# Optional CLI-only overrides can still be passed on startup if needed.
# Example:
# ./.venv/bin/python -m backend.api.minimal_api --host 127.0.0.1 --port 8000 --llm-enabled --llm-model qwen-plus --llm-base-url https://dashscope-intl.aliyuncs.com/compatible-mode/v1
