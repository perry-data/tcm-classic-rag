      "query": "六经病应该怎么办？",
      "question_type": "general_overview",
      "question_type_label": "泛问/总括类",
      "expected_mode": "weak_with_review_notice",
      "gold_record_ids": [
        "safe:main_passages:ZJSHL-CH-006-P-0065",
