      "gold_evidence_spans": [
        {
          "passage_id": "ZJSHL-CH-006-P-0065",
          "record_id": "safe:main_passages:ZJSHL-CH-006-P-0065",
          "evidence_role": "secondary",
          "quote": "三阳受邪，为病在表，法当汗解。然三阳亦有便入腑者，入腑则宜下，故云未入于腑者，可汗而已。",
          "rationale": "general_overview 正式化修正 v1：三阳受邪在表可汗，给出六经治法的阳经原则。",
          "chapter_id": "ZJSHL-CH-006",
          "chapter_title": "伤寒例第三"
        },
        {
          "passage_id": "ZJSHL-CH-006-P-0073",
          "record_id": "safe:main_passages:ZJSHL-CH-006-P-0073",
          "evidence_role": "secondary",
          "quote": "三阴受邪，为病在里，于法当下。然三阴亦有在经者，在经则宜汗，故云已入于腑者，可下而已。经曰：临病之工，宜须两审。",
          "rationale": "general_overview 正式化修正 v1：三阴受邪在里可下，给出六经治法的阴经原则。",
          "chapter_id": "ZJSHL-CH-006",
          "chapter_title": "伤寒例第三"
        },
        {
          "passage_id": "ZJSHL-CH-008-P-0207",
          "record_id": "safe:main_passages:ZJSHL-CH-008-P-0207",
          "evidence_role": "secondary",
          "quote": "太阳病，头痛至七日已赵本作「以」上自愈者，以行其经尽故也。若欲作再经者，针足阳明，使经不传则愈。",
          "rationale": "general_overview 正式化修正 v1：太阳病七日与再经阳明语境可辅助说明六经传变下的处理。",
          "chapter_id": "ZJSHL-CH-008",
          "chapter_title": "辨太阳病脉证并治法上第五"
        },
        {
          "passage_id": "ZJSHL-CH-016-P-0009",
          "record_id": "safe:main_passages:ZJSHL-CH-016-P-0009",
          "evidence_role": "review",
          "quote": "微为亡阳，涩为亡血。伤寒脉微涩，则本是霍乱，吐利亡阳、亡血，吐利止，伤寒之邪未已，还是伤寒，却四五日邪传阴经之时，里虚遇邪，必作自利，本呕者，邪甚于上，又利者，邪甚于下，先霍乱里气大虚，又伤寒之邪，再传为吐利，是重虚也，故为不治。若欲似大便，而反失气仍不利者，利为虚，不利为实，欲大便而反失气，里气热也，此属阳明，便必硬也。十三日愈者，伤寒六日，传遍三阴三阳，后六日再传经尽，则阴阳之气和，大邪之气去而愈也。",
          "rationale": "general_overview 正式化修正 v1：霍乱/伤寒语境中提到传遍三阴三阳，只作宽主题核对材料。",
          "chapter_id": "ZJSHL-CH-016",
          "chapter_title": "辨霍乱病脉证并治法第十三"
        },
        {
          "passage_id": "ZJSHL-CH-006-P-0074",
          "record_id": "safe:main_passages:ZJSHL-CH-006-P-0074",
          "evidence_role": "review",
          "quote": "若两感于寒者，一日太阳受之，即与少阴俱病，则头痛、口乾、烦满而渴；二日阳明受之，即与太阴俱病，则腹满身热、不欲食、谵语；三日少阳受之，即与厥阴俱病，则耳聋，囊缩而厥，水浆不入，不知人者，六日死。若三阴三阳、六脏六腑皆受病，则荣卫不行；腑脏赵本作「脏腑」不通，则死矣。",
          "rationale": "general_overview 正式化修正 v1：两感于寒涉及三阴三阳并病，只能作边界核对。",
          "chapter_id": "ZJSHL-CH-006",
          "chapter_title": "伤寒例第三"
        },
        {
          "passage_id": "ZJSHL-CH-006-P-0076",
          "record_id": "safe:main_passages:ZJSHL-CH-006-P-0076",
          "evidence_role": "review",
          "quote": "其不两感于寒，更不传经，不加异气者，至七日太阳病衰，头痛少愈也；八日阳明病衰，身热少歇也；九日少阳病衰，耳聋微闻也；十日太阴病衰，腹减如故，则思饮食；十一日少阴病衰，渴止舌乾，已而嚏也；十二日厥阴病衰，囊纵，少腹微下，大气皆去，病患精神爽慧也。",
          "rationale": "general_overview 正式化修正 v1：六经病衰次序属于预后/传经语境，不作强主证据。",
          "chapter_id": "ZJSHL-CH-006",
          "chapter_title": "伤寒例第三"
        }
      ],
